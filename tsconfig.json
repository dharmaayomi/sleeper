{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases mapping to match existing jsconfig */

    "paths": {
      "#components": ["./src/components"],
      "#components/*": ["./src/components/*"],
      "#constants": ["./src/constants"],
      "#constants/*": ["./src/constants/*"],
      "#hooks": ["./src/hooks"],
      "#hooks/*": ["./src/hooks/*"],
      "#store": ["./src/store"],
      "#store/*": ["./src/store/*"],
      "#windows": ["./src/windows"],
      "#windows/*": ["./src/windows/*"]
    }
  },
  "include": ["src"]
}
